# Puertos públicos
APP_PORT=3000
FRONTEND_PORT=5173
N8N_PORT=5689

# Backend / MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tdd_db
DB_USER=tdd_user
DB_PASSWORD=tdd_password

# Docker Compose / contenedor MySQL
MYSQL_DATABASE=tdd_db
MYSQL_USER=tdd_user
MYSQL_PASSWORD=tdd_password
MYSQL_ROOT_PASSWORD=change_this_root_password

# Autenticación
JWT_SECRET=change_this_jwt_secret_in_production
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_BASE_URL=http://localhost:3000

# Pipeline editorial
OPENCODE_SHARED_DIR=/shared/jobs
BACKEND_API_BASE_URL=http://backend:3000
OPENCODE_AUTO_PROCESS=true
OPENCODE_AUTO_COMPLETE_JOB=true
OPENCODE_JOB_POLL_MS=5000
OPENCODE_PROVIDER_ID=opencode
OPENCODE_PROVIDER_NAME=OpenCode
OPENCODE_PROVIDER_NPM=__builtin__
OPENCODE_MODEL_ID=minimax-m2.5-free
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
MINIMAX_API_KEY=

# n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_this_n8n_password
